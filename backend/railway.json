{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci",
    "watchPatterns": ["**/*.js", "package.json"]
  },
  "deploy": {
    "startCommand": "node initDb.js && node server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}